{
  "name": "@s-core/homelab-backend",
  "version": "1.0.0",
  "description": "Homelab",
  "author": "",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "homepage": "#readme",
  "repository": {
    "type": "git",
    "url": "git+.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "typescript",
    "esm",
    "cjs",
    "types",
    "di"
  ],
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "npm run generate:version",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json && node -e \"require('fs').writeFileSync('dist/esm/package.json', JSON.stringify({type:'module'}))\"",
    "build:types": "tsc -p tsconfig.types.json",
    "build": "npm run clean && npm run build:types && npm run build:cjs && npm run build:esm",
    "generate:version": "node -e \"require('s-application/scripts/generate-version').generateVersionFile('./package.json', './src/version.ts')\"",
    "prepublishOnly": "npm run build",
    "pack:dry": "npm pack --dry-run",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "api:generate": "ts-node -r tsconfig-paths/register src/scripts/buildTypes.ts",
    "start": "ts-node -r tsconfig-paths/register src/index.ts",
    "dev": "ts-node-dev -r tsconfig-paths/register src/index.ts"
  },
  "dependencies": {
    "@s-core/homelab": "^0.0.1",
    "@s-core/server": "^0.0.1",
    "@s-core/core": "^0.0.1",
    "@types/ajv": "^0.0.5",
    "@types/axios": "^0.9.36",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "ajv": "^8.17.1",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "openapi-typescript": "^7.10.1",
    "openapi-typescript-fetch": "^2.2.1",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.0.0",
    "vitest": "^0.0.0",
    "rimraf": "^6.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  }
}