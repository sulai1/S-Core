{
  "name": "@s-core/talktogether-server",
  "version": "0.0.1",
  "main": "dist/app.js",
  "types": "dist/app.d.ts",
  "scripts": {
    "build": "npm run build:deps && npx tsc",
    "build:deps": "npm run build --workspace @s-core/core --workspace @s-core/client --workspace @s-core/server --workspace @s-core/talktogether",
    "postbuild": "node ./scripts/copy.js",
    "start": "node dist/app.js",
    "dev": "ts-node app.ts",
    "dev:watch": "nodemon",
    "debug": "ts-node app.ts",
    "file": "nodemon",
    "test": "jest",
    "lint": "eslint --ext .js,.ts,.vue ./",
    "test:debug": "cross-env NODE_ENV=development jest",
    "deploy": "bash deploy.sh",
    "typeorm": "npx typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm migration:generate -- -d src/data-source.ts",
    "migration:create": "npm run typeorm migration:create",
    "migration:run": "npm run typeorm migration:run -- -d src/data-source.ts",
    "migration:revert": "npm run typeorm migration:revert -- -d src/data-source.ts",
    "migration:show": "npm run typeorm migration:show -- -d src/data-source.ts"
  },
  "author": "Sascha Wernegger",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@s-core/core": "^0.0.1",
    "@s-core/server": "^1.0.0",
    "@s-core/talktogether": "^0.0.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-session": "^1.18.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.16.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.17.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^25.3.2",
    "@types/pdfkit": "^0.13.9",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}