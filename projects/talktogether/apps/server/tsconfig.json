{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "app.ts",
    "debug.ts",
    "src/**/*.ts",
    "scripts/**/*.ts",
    "migrations/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "test",
    "src/routes"
  ],
}