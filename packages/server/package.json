  "type": "module",
  "main": "./dist/cjs/indext.js",
  "types": "./dist/cjs/indext.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/indext.d.ts",
      "import": "./dist/cjs/indext.js",
      "default": "./dist/cjs/indext.js"
    }
  },
  "scripts": {
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "create-api": "ts-node -r tsconfig-paths/register src/script/ .ts",
    "docs": "typedoc --out docs src",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "clean:node-modules": "node -e \"require('node:fs').rmSync('node_modules',{recursive:true,force:true,maxRetries:10,retryDelay:200})\""
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.1",
    "@s-core/client": "^0.0.1",
    "@s-core/core": "^0.0.1",
    "@types/express": "^5.0.6",
    "ajv": "^8.18.0",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "openapi-types": "^12.1.3",
    "openapi-typescript": "^7.13.0",
    "openapi-typescript-fetch": "^2.2.1",
    "reflect-metadata": "^0.2.2",
    "supertest": "^7.2.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "pg": "^8.19.0",
    "sqlite3": "^5.1.7"
  }
