{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist/cjs",
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "typeRoots": [
      "./node_modules/openapi-typescript-fetch"
    ],
  },
  "include": [
    "indext.ts",
    "src/**/*.ts",
    "test/**/*.ts",
    "src/api/openapi/**/*.ts",
    "test/buildTypes.test.ts"
  ],
  "exclude": [
    "node_modules",
    "coverage",
    "dist"
  ]
}