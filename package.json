{
  "name": "@s-core/workspace",
  "version": "0.0.1",
  "description": "workspace for packages and webapps",
  "license": "ISC",
  "author": "Sascha Wernegger",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint:workspaces": "npm run lint --workspaces --if-present",
    "typecheck:workspaces": "npm run typecheck --workspaces --if-present",
    "check": "npm run lint && npm run typecheck",
    "docs": "typedoc --out docs src",
    "build": "npm run build --workspaces --if-present",
    "watch:packages:client": "npm run watch --workspace @s-core/client",
    "watch:packages:core": "npm run watch --workspace @s-core/core",
    "watch:packages:server": "npm run watch --workspace @s-core/server",
    "watch:packages:talktogether": "npm run watch --workspace @s-core/talktogether",
    "watch:packages:loki": "npm run watch --workspace @s-core/loki",
    "watch:packages:nginx-proxy-manager": "npm run watch --workspace @s-core/nginx-proxy-manager",
    "watch:packages": "concurrently -n client,core,server,talktogether,loki,nginx-proxy-manager -c blue,green,magenta,cyan,yellow,red \"npm run watch:packages:client\" \"npm run watch:packages:core\" \"npm run watch:packages:server\" \"npm run watch:packages:talktogether\" \"npm run watch:packages:loki\" \"npm run watch:packages:nginx-proxy-manager\"",
    "deps:install": "npm install --workspaces",
    "deps:clean": "npm run clean:node-modules --workspaces --if-present && rimraf node_modules",
    "deps:update": "npm update --workspaces",
    "deps:outdated": "npm outdated --workspaces",
    "deps:audit": "npm audit --workspaces",
    "deps:add": "npm install --workspaces",
    "clean:node-modules": "rimraf node_modules"
  },
  "workspaces": [
    "packages/*",
    "projects/*/apps/*"
  ],
  "dependencies": {
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "rimraf": "^5.0.5"
  }
}